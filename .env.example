# Copy to `.env` and/or `.env.local`, then fill real values. Never commit filled files.
#
# Rotation (regenerate if ever leaked or committed): MONGODB_URI, IMGBB_API_KEY,
# SSO_CLIENT_SECRET, SESSION_SECRET.

# --- Camera app database (Atlas: cluster hostname is not the database name) ---
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=MyCluster
MONGODB_DB=camera

# Optional pool tuning (Atlas + serverless)
# MONGODB_MAX_POOL_SIZE=10
# MONGODB_MIN_POOL_SIZE=0

# --- SSO OAuth / OIDC ---
SSO_BASE_URL=https://sso.example.com
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
# Optional: OAuth redirect_uri is taken from the incoming request (/api/auth/callback).
# Keep only if you rely on tooling that still reads SSO_REDIRECT_URI.
# SSO_REDIRECT_URI=http://localhost:3000/api/auth/callback

# --- imgbb (submissions / frames / logos) ---
IMGBB_API_KEY=

# --- App URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Multi-domain (same Vercel project): Camera vs FunFitFan (FFF) — see lib/site-hosts.ts + middleware.ts
# NEXT_PUBLIC_CAMERA_ORIGIN=https://camera.messmass.com
# (Personal reel opened from an installed FFF PWA uses this origin in a new tab so playback runs in the full browser.)
# NEXT_PUBLIC_FFF_ORIGIN=https://fff.messmass.com
# FFF_HOSTNAMES=fff.messmass.com,funfitfan.messmass.com
# CAMERA_HOSTNAMES=camera.messmass.com,www.camera.messmass.com
# Optional: share login across *.messmass.com (set only if SSO allowlists all callback URLs on those hosts)
# SESSION_COOKIE_DOMAIN=.messmass.com

# Optional: HMAC secret for FunFitFan friend share links (/fff/share/...). Min 16 chars; use a long random string in production.
# FFF_SHARE_LINK_SECRET=

NODE_ENV=development

# Production: dev-login, migrate, debug/*, test-db, test-frames stay 404 unless true
# ALLOW_DANGEROUS_DEV_ROUTES=false

# Reserved for signed sessions / crypto (also used to HMAC-sign OAuth PKCE `state` so login works without a pending cookie)
SESSION_SECRET=
# Optional: override secret for OAuth signed state only (else SESSION_SECRET or SSO_CLIENT_SECRET is used)
# OAUTH_PKCE_STATE_SECRET=

# --- Optional: Upstash Redis (REST) — distributed API rate limits on Vercel ---
# Create a database at https://upstash.com and paste REST URL + token.
# If unset, rate limits use in-memory buckets (per serverless instance).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
